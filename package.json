{
	"name": "cookie-tasting",
	"homepage": "https://tarosky.co.jp",
	"engines": {
		"node": ">=22.0"
	},
	"repository": {
		"type": "git",
		"url": "http://github.com/tarosky/cookie-tasting.git"
	},
	"scripts": {
		"prepare": "husky",
		"start": "wp-env start",
		"update": "wp-env start --update",
		"cli": "wp-env run cli wp",
		"env": "wp-env",
		"package": "npm run build:js && npm run dump",
		"build:js": "grab-deps js src/js dist/js",
		"dump": "grab-deps dump dist",
		"watch": "npm-watch",
		"lint": "wp-scripts lint-js src/js/**/*.js",
		"test": "wp-env run tests-cli ./wp-content/plugins/cookie-tasting/vendor/bin/phpunit -c ./wp-content/plugins/cookie-tasting/phpunit.xml.dist"
	},
	"watch": {
		"build:js": {
			"patterns": ["src/js"],
			"extensions": "js,jsx"
		}
	},
	"author": "Tarosky inc.",
	"license": "GPL-3.0-or-later",
	"devDependencies": {
		"@kunoichi/grab-deps": "^3.0.0",
		"@wordpress/env": "^8.4.0",
		"@wordpress/scripts": "^30.0.0",
		"autoprefixer": "^10.4.16",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"npm-watch": "^0.13.0",
		"postcss": "^8.4.33",
		"postcss-cli": "^11.0.0"
	},
	"lint-staged": {
		"*.js": "npm run lint",
		"*.php": "composer lint"
	}
}
